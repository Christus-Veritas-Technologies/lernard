// apps/whatsapp/.env.example
// Copy to .env and fill in your values.

# ─── Database (same as apps/api) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lernard

# ─── Lernard API ─────────────────────────────────────────────────────────────
# Base URL of the running apps/api instance
LERNARD_API_URL=http://localhost:3000

# ─── Anthropic (Claude Haiku for intent classification) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Token encryption ─────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of stored JWT tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_TOKEN_ENCRYPTION_KEY=your_64_char_hex_string_here

# ─── WhatsApp session storage ─────────────────────────────────────────────────
# Directory where wweb.js stores the browser session after QR scan
WHATSAPP_SESSION_PATH=./.wwebjs_auth

# ─── Optional: QR code HTTP endpoint ─────────────────────────────────────────
# Secret to guard the /whatsapp/qr endpoint (leave blank to disable the endpoint)
WHATSAPP_ADMIN_SECRET=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Shown in upgrade prompts
APP_URL=https://app.lernard.com

# ─── Port ─────────────────────────────────────────────────────────────────────
PORT=3001
