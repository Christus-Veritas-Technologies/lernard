# ---------------------------------------------------------------------------
# Lernard Native App — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the JS bundle and
# visible to client-side code. Do NOT put secrets here.
# ---------------------------------------------------------------------------

# Base URL of the Lernard API (no trailing slash).
# Consumed via Constants.expoConfig.extra.apiUrl in native-api.ts.
# Requires app.config.js (dynamic config) to pipe this into extra.apiUrl —
# see README for setup instructions.
# Development default when unset: http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001
