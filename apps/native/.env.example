# ---------------------------------------------------------------------------
# Lernard Native App — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the JS bundle and
# visible to client-side code. Do NOT put secrets here.
# ---------------------------------------------------------------------------

# Base URL of the Lernard API (no trailing slash).
# Development default when unset: http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3001

# Deep-link scheme used as the OAuth redirect URI (e.g. lernard://).
# Must match the `scheme` in app.config.js and your OAuth provider settings.
# Development default when unset: lernard
EXPO_PUBLIC_APP_SCHEME=lernard

# ---------------------------------------------------------------------------
# Build-time / EAS variables (not bundled into the JS bundle)
# ---------------------------------------------------------------------------

# EAS project ID from expo.dev — used by `eas build` and `eas update`.
EAS_PROJECT_ID=4bf1a62f-7d02-4dcc-ae8a-b7c32b1ee7a6

# Expo account owner — must match the account that owns the EAS project.
EXPO_OWNER=johnprime

# Android application ID / package name.
# Change this for staging/production variants if needed.
EXPO_ANDROID_PACKAGE=com.christusveritastechnologies.lernard
