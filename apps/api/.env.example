DATABASE_URL=postgresql://localhost:5432/lernard
JWT_SECRET=change-me-to-a-random-secret
WEB_APP_URL=http://localhost:4000

# Anthropic Claude API - Required for AI content generation
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Google OAuth - Required for "Continue with Google"
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# SMTP - Required for magic link emails in production
# In development, magic links are printed to the console instead.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Lernard <noreply@example.com>
