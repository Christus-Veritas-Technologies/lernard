// Lernard — PostgreSQL schema via Prisma
// All entities from MAIN.md §12–14

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  STUDENT
  GUARDIAN
  TEACHER
  SCHOOL_ADMIN
}

enum Plan {
  EXPLORER
  /// Legacy student plan — kept for migration safety
  SCHOLAR
  /// Legacy guardian/family plan — kept for migration safety
  HOUSEHOLD
  STUDENT_SCHOLAR
  STUDENT_PRO
  GUARDIAN_FAMILY_STARTER
  GUARDIAN_FAMILY_STANDARD
  GUARDIAN_FAMILY_PREMIUM
}

enum LearningMode {
  GUIDE
  COMPANION
}

enum AgeGroup {
  PRIMARY
  SECONDARY
  UNIVERSITY
  PROFESSIONAL
}

enum LearningGoal {
  EXAM_PREP
  KEEP_UP
  LEARN_NEW
  FILL_GAPS
}

enum StrengthLevel {
  STRONG
  DEVELOPING
  NEEDS_WORK
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum PaperType {
  PAPER1
  PAPER2
}

enum QuizDifficulty {
  FOUNDATION
  STANDARD
  CHALLENGING
  EXTENSION
}

enum SessionType {
  LESSON
  QUIZ
}

enum ProjectAcademicLevel {
  GRADE7
  OLEVEL
  ALEVEL
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  FILL_BLANK
  SHORT_ANSWER
  ORDERING
  STRUCTURED
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?  // null for social-only accounts
  googleId     String?  @unique
  role         Role     @default(STUDENT)
  plan         Plan     @default(EXPLORER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Profile
  profilePictureUrl String?
  ageGroup       AgeGroup?
  grade          String?
  learningGoal   LearningGoal?
  timezone       String    @default("UTC")
  learningMode   LearningMode @default(GUIDE)
  appearance      String    @default("system")
  preferredDepth String    @default("standard") // quick | standard | deep
  sessionLength  Int       @default(20) // minutes
  dailyGoal      Int       @default(1)  // sessions per day
  notificationsEnabled Boolean @default(true)

  // Study preferences (extended)
  supportLevel         String  @default("moderate") // "minimal" | "moderate" | "full"
  textSize             String  @default("medium")   // "small" | "medium" | "large" | "xl"
  reducedMotion        Boolean @default(false)

  // Notification preferences
  reminderEnabled           Boolean @default(true)
  reminderTime              String  @default("07:00") // "HH:MM"
  streakAlertEnabled        Boolean @default(true)
  growthAreaNudgeEnabled    Boolean @default(true)
  growthAreaNudgeFrequency  String  @default("daily") // "daily" | "weekly" | "in_app_only"
  planLimitAlertEnabled     Boolean @default(true)
  weeklyEmailEnabled        Boolean @default(true)

  // Onboarding
  onboardingComplete Boolean @default(false)
  firstLookComplete  Boolean @default(false)
  sessionCount       Int     @default(0)
  streakDays         Int     @default(0)
  lastActiveAt       DateTime?

  // Billing
  billingAnchorDay        Int?    // day of month (1–28)
  stripePriceId           String?
  stripeSubscriptionId    String?
  invalidatePermissionsAt DateTime?
  storageBytesUsed        Int     @default(0)
  planExpiresAt           DateTime? // null = no expiry (Explorer / legacy)

  // Account activation (for guardian-created child accounts)
  accountStatus       String    @default("ACTIVE")   // "ACTIVE" | "PENDING_SETUP"
  setupToken          String?   @unique
  setupTokenExpiresAt DateTime?
  setupReminderSentAt DateTime?

  // Guardian control
  controlledByGuardianId String?
  controlledBy           Guardian? @relation("GuardianStudents", fields: [controlledByGuardianId], references: [id])
  lockedSettings         String[]  @default([]) // field names locked by guardian

  // Relations
  subjects          UserSubject[]
  refreshTokens     RefreshToken[]
  settingsAudit     SettingsAudit[]
  subjectProgress   SubjectProgress[]
  lessons           Lesson[]
  quizzes           Quiz[]
  projects          Project[]
  projectDrafts     ProjectDraft[]
  quizAnswers       QuizAnswer[]
  sessions          Session[]
  conversations     Conversation[]
  pushSubscriptions PushSubscription[]
  paymentOrders     PaymentOrder[]
  whatsAppSession   WhatsAppSession?
  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

// ─── Guardian ─────────────────────────────────────────────────────────────────

model Guardian {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String?  // optional — only set if guardian configures a parental-controls PIN
  createdAt    DateTime @default(now())

  contactPreference  String @default("email")    // "email" | "push" | "both"
  dashboardDefault   String @default("overview") // "overview" | "last_viewed" | "most_recent"
    weeklyFamilySummary  Boolean @default(true)
    unsubscribeAll       Boolean @default(false)

  children     User[]          @relation("GuardianStudents")
  invites      ChildInvite[]
  settingsAudit SettingsAudit[]

  @@index([userId])
}

// ─── Companion Controls (per child, set by guardian) ─────────────────────────

model CompanionControls {
  id                 String   @id @default(cuid())
  studentId          String   @unique
  answerRevealTiming String   @default("after_quiz")  // "after_quiz" | "immediate"
  quizPassThreshold  Float    @default(0.7)            // 0.5 | 0.6 | 0.7 | 0.8 | 0.9 | 1.0
  lockedByGuardian   Boolean  @default(false)
  lastChangedAt      DateTime @updatedAt
  lastChangedBy      String   @default("Lernard")
}

// ─── Settings Audit ───────────────────────────────────────────────────────────

model SettingsAudit {
  id          String   @id @default(cuid())
  guardianId  String
  studentId   String
  setting     String
  oldValue    String
  newValue    String
  ip          String
  userAgent   String
  createdAt   DateTime @default(now())

  guardian Guardian @relation(fields: [guardianId], references: [id])
  student  User     @relation(fields: [studentId], references: [id])

  @@index([guardianId])
  @@index([studentId])
}

// ─── Child Invite ─────────────────────────────────────────────────────────────

model ChildInvite {
  id         String   @id @default(cuid())
  guardianId String
  childEmail String?
  childId    String?                              // populated for existing_account path
  type       String   @default("existing_account") // "existing_account" | "new_account"
  status     String   @default("pending")          // "pending" | "accepted" | "declined" | "cancelled"
  code       String   @unique // 6-digit
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@index([code])
  @@index([expiresAt])
  @@index([guardianId, status])
}

// ─── Magic Link Token ─────────────────────────────────────────────────────────

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  otpHash   String?
  platform  String    @default("web") // 'web' | 'native'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Refresh Token ────────────────────────────────────────────────────────────

model RefreshToken {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  revoked         Boolean   @default(false)
  replacedByHash  String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Subject ──────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  userSubjects    UserSubject[]
  subjectProgress SubjectProgress[]
  lessons         Lesson[]
  quizzes         Quiz[]
}

model UserSubject {
  id            String   @id @default(cuid())
  userId        String
  subjectId     String
  priorityIndex Int      @default(0)
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
  @@index([userId])
}

// ─── Subject Progress ─────────────────────────────────────────────────────────

model SubjectProgress {
  id            String        @id @default(cuid())
  userId        String
  subjectId     String
  strengthLevel StrengthLevel @default(DEVELOPING)
  topicScores   Json          @default("{}") // { [topic]: score 0-1 }
  updatedAt     DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
  @@index([userId])
}

// ─── Lessons, Quizzes, Sessions ─────────────────────────────────────────────

model Lesson {
  id               String           @id @default(cuid())
  userId           String
  subjectId        String?
  subjectName      String?
  topic            String
  depth            String           @default("standard") // quick | standard | deep
  status           GenerationStatus @default(QUEUED)
  estimatedMinutes Int              @default(10)
  sections         Json             @default("[]")
  sectionChecks    Json             @default("[]")
  confidenceRating Int?
  jobId            String?
  readyAt          DateTime?
  failedAt         DateTime?
  failureReason    String?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id])
  quizzes Quiz[]

  @@index([userId, createdAt])
  @@index([status])
}

model Quiz {
  id                String           @id @default(cuid())
  userId            String
  subjectId         String?
  subjectName       String?
  topic             String
  mode              LearningMode     @default(GUIDE)
  paperType         PaperType        @default(PAPER1)
  difficulty        QuizDifficulty   @default(STANDARD)
  totalQuestions    Int              @default(10)
  status            GenerationStatus @default(QUEUED)
  fromLessonId      String?
  fromConversationId String?
  currentIndex      Int              @default(0)
  score             Int              @default(0)
  weakTopics        Json             @default("[]")
  strongTopics      Json             @default("[]")
  revisitSoonTopics Json             @default("[]")
  debriefText       String?
  reviewQuestions   Json             @default("[]")
  jobId             String?
  readyAt           DateTime?
  failedAt          DateTime?
  failureReason     String?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject?  @relation(fields: [subjectId], references: [id])
  fromLesson Lesson?   @relation(fields: [fromLessonId], references: [id])
  questions  QuizQuestion[]
  answers    QuizAnswer[]

  @@index([userId, createdAt])
  @@index([status])
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId         String
  questionIndex  Int
  type           QuizQuestionType
  text           String
  options        Json?
  correctAnswer  String
  explanation    String
  subtopic       String?
  createdAt      DateTime         @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionIndex])
  @@index([quizId])
}

model QuizAnswer {
  id               String   @id @default(cuid())
  quizId           String
  userId           String
  questionIndex    Int
  answer           String
  isCorrect        Boolean
  evaluationResult String?
  feedback         String?
  submittedAt      DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionIndex])
  @@index([quizId])
  @@index([userId])
}

model Session {
  id              String      @id @default(cuid())
  userId          String
  type            SessionType
  lessonId        String?
  quizId          String?
  subjectName     String?
  topic           String
  durationMinutes Int         @default(0)
  completedAt     DateTime    @default(now())
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([type])
}

model ProjectDraft {
  id               String              @id @default(cuid())
  userId           String
  templateId       String
  subjectName      String
  level            ProjectAcademicLevel
  topicHint        String?
  studentInfo      Json
  context          Json
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects         Project[]

  @@index([userId, updatedAt])
}

model Project {
  id               String              @id @default(cuid())
  userId           String
  draftId          String?
  templateId       String
  templateName     String
  title            String
  subjectName      String
  level            ProjectAcademicLevel
  totalMarks       Int                 @default(0)
  status           GenerationStatus    @default(QUEUED)
  sections         Json                @default("[]")
  jobId            String?
  idempotencyKey   String?
  readyAt          DateTime?
  failedAt         DateTime?
  failureReason    String?
  pdfReadyAt       DateTime?
  pdfObjectKey     String?
  pdfFileName      String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  draft            ProjectDraft?       @relation(fields: [draftId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@unique([userId, idempotencyKey])
}

// ─── Chat ───────────────────────────────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  userId      String
  title       String
  lastMessage String    @default("")
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  blocks         Json
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Payments ────────────────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model PaymentOrder {
  id             String        @id @default(cuid())
  userId         String
  reference      String        @unique
  plan           Plan
  amountUsd      Float
  status         PaymentStatus @default(PENDING)
  paynowPollUrl  String?
  paynowResponse Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reference])
  @@index([userId, status])
}

// ─── WhatsApp Sessions ────────────────────────────────────────────────────────
// Stores one session per WhatsApp phone number.
// Tokens are AES-256-GCM encrypted before storage.

model WhatsAppSession {
  id              String   @id @default(cuid())
  /// E.164 format, e.g. "263771234567@c.us" (wweb.js phone ID)
  phoneNumber     String   @unique
  userId          String?  @unique
  /// WhatsAppState enum value (string)
  state           String   @default("UNAUTHENTICATED")
  /// JSON blob: varies per state (AuthStateData | QuizStateData | etc.)
  stateData       Json?
  /// AES-256-GCM encrypted JWT access token
  accessTokenEnc  String?
  /// AES-256-GCM encrypted JWT refresh token
  refreshTokenEnc String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneNumber])
  @@index([userId])
}
