// Lernard — PostgreSQL schema via Prisma
// All entities from MAIN.md §12–14

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  STUDENT
  GUARDIAN
  TEACHER
  SCHOOL_ADMIN
}

enum Plan {
  EXPLORER
  SCHOLAR
  HOUSEHOLD
  CAMPUS
}

enum LearningMode {
  GUIDE
  COMPANION
}

enum AgeGroup {
  PRIMARY
  SECONDARY
  UNIVERSITY
  PROFESSIONAL
}

enum LearningGoal {
  EXAM_PREP
  KEEP_UP
  LEARN_NEW
  FILL_GAPS
}

enum StrengthLevel {
  STRONG
  DEVELOPING
  NEEDS_WORK
}

enum GenerationStatus {
  GENERATING
  READY
  FAILED
}

enum SessionType {
  LESSON
  QUIZ
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
  FILL_BLANK
  SHORT_ANSWER
  ORDERING
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String?  // null for social-only accounts
  googleId     String?  @unique
  role         Role     @default(STUDENT)
  plan         Plan     @default(EXPLORER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Profile
  profilePictureUrl String?
  ageGroup       AgeGroup?
  grade          String?
  learningGoal   LearningGoal?
  timezone       String    @default("UTC")
  learningMode   LearningMode @default(GUIDE)
  appearance      String    @default("system")
  preferredDepth String    @default("standard") // quick | standard | deep
  sessionLength  Int       @default(20) // minutes
  dailyGoal      Int       @default(1)  // sessions per day
  notificationsEnabled Boolean @default(true)

  // Onboarding
  onboardingComplete Boolean @default(false)
  firstLookComplete  Boolean @default(false)
  sessionCount       Int     @default(0)
  streakDays         Int     @default(0)
  lastActiveAt       DateTime?

  // Billing
  billingAnchorDay        Int?    // day of month (1–28)
  stripePriceId           String?
  stripeSubscriptionId    String?
  invalidatePermissionsAt DateTime?

  // Guardian control
  controlledByGuardianId String?
  controlledBy           Guardian? @relation("GuardianStudents", fields: [controlledByGuardianId], references: [id])
  lockedSettings         String[]  @default([]) // field names locked by guardian

  // Relations
  subjects          UserSubject[]
  refreshTokens     RefreshToken[]
  settingsAudit     SettingsAudit[]
  subjectProgress   SubjectProgress[]
  lessons           Lesson[]
  quizzes           Quiz[]
  quizAnswers       QuizAnswer[]
  sessions          Session[]
  conversations     Conversation[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

// ─── Guardian ─────────────────────────────────────────────────────────────────

model Guardian {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String?  // optional — only set if guardian configures a parental-controls PIN
  createdAt    DateTime @default(now())

  children     User[]          @relation("GuardianStudents")
  invites      ChildInvite[]
  settingsAudit SettingsAudit[]

  @@index([userId])
}

// ─── Companion Controls (per child, set by guardian) ─────────────────────────

model CompanionControls {
  id                 String   @id @default(cuid())
  studentId          String   @unique
  showCorrectAnswers Boolean  @default(true)
  allowHints         Boolean  @default(true)
  allowSkip          Boolean  @default(false)
  lockedByGuardian   Boolean  @default(false)
  lastChangedAt      DateTime @updatedAt
  lastChangedBy      String   @default("Lernard")
}

// ─── Settings Audit ───────────────────────────────────────────────────────────

model SettingsAudit {
  id          String   @id @default(cuid())
  guardianId  String
  studentId   String
  setting     String
  oldValue    String
  newValue    String
  ip          String
  userAgent   String
  createdAt   DateTime @default(now())

  guardian Guardian @relation(fields: [guardianId], references: [id])
  student  User     @relation(fields: [studentId], references: [id])

  @@index([guardianId])
  @@index([studentId])
}

// ─── Child Invite ─────────────────────────────────────────────────────────────

model ChildInvite {
  id         String   @id @default(cuid())
  guardianId String
  childEmail String?
  code       String   @unique // 6-digit
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@index([code])
  @@index([expiresAt])
}

// ─── Magic Link Token ─────────────────────────────────────────────────────────

model MagicLinkToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  otpHash   String?
  platform  String    @default("web") // 'web' | 'native'
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Refresh Token ────────────────────────────────────────────────────────────

model RefreshToken {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  revoked         Boolean   @default(false)
  replacedByHash  String?
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ─── Subject ──────────────────────────────────────────────────────────────────

model Subject {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  userSubjects    UserSubject[]
  subjectProgress SubjectProgress[]
  lessons         Lesson[]
  quizzes         Quiz[]
}

model UserSubject {
  id            String   @id @default(cuid())
  userId        String
  subjectId     String
  priorityIndex Int      @default(0)
  createdAt     DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
  @@index([userId])
}

// ─── Subject Progress ─────────────────────────────────────────────────────────

model SubjectProgress {
  id            String        @id @default(cuid())
  userId        String
  subjectId     String
  strengthLevel StrengthLevel @default(DEVELOPING)
  topicScores   Json          @default("{}") // { [topic]: score 0-1 }
  updatedAt     DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
  @@index([userId])
}

// ─── Lessons, Quizzes, Sessions ─────────────────────────────────────────────

model Lesson {
  id               String           @id @default(cuid())
  userId           String
  subjectId        String?
  subjectName      String?
  topic            String
  depth            String           @default("standard") // quick | standard | deep
  status           GenerationStatus @default(GENERATING)
  estimatedMinutes Int              @default(10)
  sections         Json             @default("[]")
  sectionChecks    Json             @default("[]")
  confidenceRating Int?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id])
  quizzes Quiz[]

  @@index([userId, createdAt])
  @@index([status])
}

model Quiz {
  id                String           @id @default(cuid())
  userId            String
  subjectId         String?
  subjectName       String?
  topic             String
  mode              LearningMode     @default(GUIDE)
  totalQuestions    Int              @default(10)
  status            GenerationStatus @default(GENERATING)
  fromLessonId      String?
  fromConversationId String?
  currentIndex      Int              @default(0)
  score             Int              @default(0)
  weakTopics        Json             @default("[]")
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    Subject?  @relation(fields: [subjectId], references: [id])
  fromLesson Lesson?   @relation(fields: [fromLessonId], references: [id])
  questions  QuizQuestion[]
  answers    QuizAnswer[]

  @@index([userId, createdAt])
  @@index([status])
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId         String
  questionIndex  Int
  type           QuizQuestionType
  text           String
  options        Json?
  correctAnswer  String
  explanation    String
  createdAt      DateTime         @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionIndex])
  @@index([quizId])
}

model QuizAnswer {
  id            String   @id @default(cuid())
  quizId         String
  userId         String
  questionIndex  Int
  answer         String
  isCorrect      Boolean
  submittedAt    DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, questionIndex])
  @@index([quizId])
  @@index([userId])
}

model Session {
  id              String      @id @default(cuid())
  userId          String
  type            SessionType
  lessonId        String?
  quizId          String?
  subjectName     String?
  topic           String
  durationMinutes Int         @default(0)
  completedAt     DateTime    @default(now())
  createdAt       DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([type])
}

// ─── Chat ───────────────────────────────────────────────────────────────────

model Conversation {
  id          String    @id @default(cuid())
  userId      String
  title       String
  lastMessage String    @default("")
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  blocks         Json
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}
